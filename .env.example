# ───────────────────────────────────────────────────────────────
# Shared environment for docker-compose and local development.
# Copy to `.env` and adjust. NEVER commit the real `.env`.
# ───────────────────────────────────────────────────────────────

# --- Postgres ---
POSTGRES_USER=skribble
POSTGRES_PASSWORD=skribble_dev_password
POSTGRES_DB=skribble
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Backend ---
NODE_ENV=development
BACKEND_PORT=3000
# Connection strings (point at the docker service names when running in compose)
DATABASE_URL=postgresql://skribble:skribble_dev_password@localhost:5432/skribble?schema=public
REDIS_URL=redis://localhost:6379

# JWT secrets — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# CORS / client
CLIENT_ORIGIN=http://localhost:5173

# --- Frontend (Vite needs the VITE_ prefix to expose vars to the client) ---
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000
