{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": { "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/../tsconfig.json" }] },
  "moduleNameMapper": {
    "^@skribble/shared$": "<rootDir>/../../../packages/shared/dist/index.js"
  }
}
